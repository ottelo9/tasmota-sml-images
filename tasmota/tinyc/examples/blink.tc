// Blink LED on pin 8 (classic Arduino blink)
#define LED_PIN 8
#define INPUT         0x01
#define OUTPUT        0x03
#define INPUT_PULLUP  0x05
#define INPUT_PULLDOWN 0x09

int main() {
    pinMode(LED_PIN, OUTPUT);

    int i = 0;
    while (i < 10) {
        digitalWrite(LED_PIN, 1);
        delay(500);
        digitalWrite(LED_PIN, 0);
        delay(500);
        i++;
    }
    return 0;
}
