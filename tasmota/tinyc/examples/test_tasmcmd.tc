// Test: Tasmota command execution and JSON response parsing
// Tests tasmCmd, responseAppend, sensorGet
// No hardware dependencies — uses built-in Tasmota commands

char buf[256];
char response[256];

int main() {
    print("=== Tasmota Commands Test ===\n\n");

    // Test 1: Get device status
    print("--- Status 0 ---\n");
    int r = tasmCmd("Status", response);
    char msg[64];
    sprintfInt(msg, "tasmCmd Status returned: %d\n", r);
    printStr(msg);
    if (r > 0) {
        // Truncate for display
        char short_resp[80];
        strSub(response, short_resp, 0, 75);
        sprintfStr(msg, "  Response: %s...\n", short_resp);
        printStr(msg);
    }

    // Test 2: Get network info
    print("\n--- Status 5 (Network) ---\n");
    r = tasmCmd("Status 5", response);
    if (r > 0) {
        char short_resp[80];
        strSub(response, short_resp, 0, 75);
        sprintfStr(msg, "  Response: %s...\n", short_resp);
        printStr(msg);
    }

    // Test 3: Get firmware info
    print("\n--- Status 2 (Firmware) ---\n");
    r = tasmCmd("Status 2", response);
    if (r > 0) {
        char short_resp[80];
        strSub(response, short_resp, 0, 75);
        sprintfStr(msg, "  Response: %s...\n", short_resp);
        printStr(msg);
    }

    // Test 4: Backlog (multiple commands)
    print("\n--- Backlog test ---\n");
    r = tasmCmd("Backlog0 Timezone 99; Timezone 1", response);
    sprintfInt(msg, "Backlog returned: %d\n", r);
    printStr(msg);

    // Test 5: sensorGet — read sensor by index
    print("\n--- sensorGet ---\n");
    float temp = sensorGet(0);
    float hum = sensorGet(1);
    sprintfFloat(msg, "  Sensor 0 (temp): %.1f\n", temp);
    printStr(msg);
    sprintfFloat(msg, "  Sensor 1 (hum):  %.1f\n", hum);
    printStr(msg);

    print("\n=== Tasmota command tests complete ===\n");
}

void JsonCall() {
    // This fires on teleperiod JSON — show we can process it
    char msg[64];
    sprintfFloat(msg, "JsonCall: temp=%.1f", tasm_temp);
    sprintfAppendFloat(msg, " hum=%.1f\n", tasm_hum);
    printStr(msg);
}
