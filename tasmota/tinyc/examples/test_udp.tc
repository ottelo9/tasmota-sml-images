// Test: UDP send and receive
// Sends a UDP packet to itself (loopback) and checks reception
// Requires WiFi — no special hardware

#define UDP_PORT "4444"
#define MSG_SIZE 64

char sendbuf[MSG_SIZE];
char recvbuf[MSG_SIZE];
int packets_sent;
int packets_recv;
int test_phase;

int main() {
    print("=== UDP Loopback Test ===\n\n");
    print("Sending UDP packets to own IP on port 4444\n");
    print("If firewall blocks loopback, only send count increments\n\n");
    test_phase = 1;
}

void EverySecond() {
    if (test_phase == 0) return;

    // Send a test packet every 2 seconds
    if ((tasm_second % 2) == 0) {
        packets_sent = packets_sent + 1;
        sprintfInt(sendbuf, "TinyC UDP test packet #%d", packets_sent);
        udpSend(UDP_PORT, sendbuf);

        char msg[80];
        sprintfInt(msg, "Sent packet #%d\n", packets_sent);
        printStr(msg);
    }

    // Check for received packets
    if (udpReady(UDP_PORT)) {
        int r = udpRecv(UDP_PORT, recvbuf);
        if (r > 0) {
            packets_recv = packets_recv + 1;
            char msg[128];
            sprintfInt(msg, "Received packet #%d: ", packets_recv);
            sprintfAppendStr(msg, "%s\n", recvbuf);
            printStr(msg);
        }
    }

    // Report every 10 seconds
    if ((tasm_second % 10) == 0) {
        char msg[80];
        sprintfInt(msg, "Stats: sent=%d", packets_sent);
        sprintfAppendInt(msg, " recv=%d\n", packets_recv);
        printStr(msg);
    }

    // Stop after 30 packets
    if (packets_sent >= 30) {
        test_phase = 0;
        char msg[80];
        sprintfInt(msg, "\nDone: %d sent, ", packets_sent);
        sprintfAppendInt(msg, "%d received\n", packets_recv);
        printStr(msg);
    }
}

void WebPage() {
    char html[128];
    sprintfInt(html, "<p>UDP packets sent: <b>%d</b></p>", packets_sent);
    sprintfAppendInt(html, "<p>UDP packets received: <b>%d</b></p>", packets_recv);
    webSend(html);
}
