// Test: Serial port API
// Tests serialBegin with config, write, read, close
// Requires 2 free GPIO pins (connect TX to RX for loopback test)
// Change RX_PIN and TX_PIN to match your board

#define RX_PIN 16
#define TX_PIN 17
#define BAUD   9600
#define CONFIG  3   // 8N1: (8-5) + (0*8) + (1-1)*4 = 3

int port_open;
int bytes_sent;
int bytes_recv;
char recv_buf[128];
int recv_pos;

int main() {
    print("=== Serial Port Test ===\n\n");
    char msg[64];
    sprintfInt(msg, "Opening serial on RX=%d", RX_PIN);
    sprintfAppendInt(msg, " TX=%d", TX_PIN);
    sprintfAppendInt(msg, " baud=%d\n", BAUD);
    printStr(msg);

    int r = serialBegin(RX_PIN, TX_PIN, BAUD, CONFIG, 256);
    if (r == 1) {
        print("Serial port opened OK\n");
        port_open = 1;
    } else {
        print("Serial port FAILED to open\n");
        print("Check that pins are free and valid\n");
        port_open = 0;
        return;
    }

    // Send test string
    print("Sending test data...\n");
    serialWrite("Hello from TinyC serial!\n");
    bytes_sent = 25;

    // Send individual bytes
    serialWriteByte(0x41);  // 'A'
    serialWriteByte(0x42);  // 'B'
    serialWriteByte(0x43);  // 'C'
    serialWriteByte(0x0A);  // newline
    bytes_sent = bytes_sent + 4;

    sprintfInt(msg, "Sent %d bytes\n", bytes_sent);
    printStr(msg);
    print("If TX-RX are looped, data appears below.\n\n");
}

void Every50ms() {
    if (!port_open) return;

    // Check for received data
    while (serialAvailable() > 0) {
        int b = serialRead();
        if (b >= 0) {
            bytes_recv = bytes_recv + 1;
            if (recv_pos < 126) {
                recv_buf[recv_pos] = b;
                recv_pos = recv_pos + 1;
                recv_buf[recv_pos] = 0;
            }
            if (b == 10) {  // newline — print line
                char msg[160];
                sprintfStr(msg, "RX: %s", recv_buf);
                printStr(msg);
                recv_pos = 0;
                recv_buf[0] = 0;
            }
        }
    }
}

void EverySecond() {
    if (!port_open) return;

    // Status every 10 seconds
    if ((tasm_second % 10) == 0) {
        char msg[64];
        sprintfInt(msg, "Serial stats: sent=%d", bytes_sent);
        sprintfAppendInt(msg, " recv=%d\n", bytes_recv);
        printStr(msg);
    }
}

void CleanUp() {
    if (port_open) {
        serialClose();
        print("Serial port closed\n");
    }
}

void WebPage() {
    char html[128];
    if (port_open) {
        sprintfInt(html, "<p>Serial TX: <b>%d</b> bytes</p>", bytes_sent);
        sprintfAppendInt(html, "<p>Serial RX: <b>%d</b> bytes</p>", bytes_recv);
    } else {
        strcpy(html, "<p>Serial port not open</p>");
    }
    webSend(html);
}
