// Test: Event callback (rules processing)
// The Event() callback fires on sensor updates, switch changes, MQTT messages
// The JSON payload is passed as a char array parameter

int event_count;
char last_event[256];

int main() {
    event_count = 0;
    print("Event test running. Trigger events via:\n");
    print("  - Switch toggle\n");
    print("  - MQTT publish\n");
    print("  - backlog rule1 on ...\n");
    print("  - Console: event test=123\n");
}

void Event(char json[]) {
    event_count = event_count + 1;
    strcpy(last_event, json);

    // Log to console
    char msg[300];
    sprintfInt(msg, "Event #%d: ", event_count);
    sprintfAppendStr(msg, "%s", json);
    printStr(msg);
    print("\n");

    // Parse specific fields from JSON
    // Example: {"Switch1":{"Action":"TOGGLE"}}
    char val[64];
    int found;

    // Try to extract common fields
    found = strToken(json, val, "POWER", 0);
    if (found > 0) {
        char report[80];
        sprintfStr(report, "  -> Power changed to: %s\n", val);
        printStr(report);
    }

    found = strToken(json, val, "Switch1", 0);
    if (found > 0) {
        char report[80];
        sprintfStr(report, "  -> Switch1 event: %s\n", val);
        printStr(report);
    }
}

void EverySecond() {
    // Periodic status in console
    if (tasm_second == 0) {
        char msg[64];
        sprintfInt(msg, "[Event test] %d events received this session\n", event_count);
        printStr(msg);
    }
}

void WebPage() {
    char html[400];
    sprintfInt(html, "<p>Events received: <b>%d</b></p>", event_count);
    if (event_count > 0) {
        sprintfAppendStr(html, "<p>Last event: <code>%s</code></p>", last_event);
    }
    webSend(html);
}
