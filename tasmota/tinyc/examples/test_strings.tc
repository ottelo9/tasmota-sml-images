// Test: String operations, sprintf, tokenizing, parsing
// All pure software — no hardware dependencies

char buf[256];
char tmp[128];
int errors;
int tests;

void check(int condition, char name[]) {
    tests = tests + 1;
    if (condition) {
        sprintfStr(buf, "  PASS: %s\n", name);
    } else {
        errors = errors + 1;
        sprintfStr(buf, "  FAIL: %s\n", name);
    }
    printStr(buf);
}

void test_strlen() {
    print("--- strlen ---\n");
    char s[32];
    strcpy(s, "hello");
    check(strlen(s) == 5, "strlen hello");
    strcpy(s, "");
    check(strlen(s) == 0, "strlen empty");
    strcpy(s, "a");
    check(strlen(s) == 1, "strlen single");
}

void test_strcmp() {
    print("--- strcmp ---\n");
    char a[32];
    char b[32];
    strcpy(a, "abc");
    strcpy(b, "abc");
    check(strcmp(a, b) == 0, "strcmp equal");
    strcpy(b, "abd");
    check(strcmp(a, b) < 0, "strcmp less");
    strcpy(b, "abb");
    check(strcmp(a, b) > 0, "strcmp greater");
}

void test_strcat() {
    print("--- strcat ---\n");
    char s[64];
    strcpy(s, "hello");
    strcat(s, " world");
    check(strcmp(s, "hello world") == 0, "strcat basic");
    check(strlen(s) == 11, "strcat length");
}

void test_sprintf() {
    print("--- sprintf ---\n");
    char s[128];

    sprintfInt(s, "val=%d", 42);
    check(strcmp(s, "val=42") == 0, "sprintfInt");

    sprintfFloat(s, "pi=%.2f", 3.14159);
    check(strcmp(s, "pi=3.14") == 0, "sprintfFloat");

    char name[16];
    strcpy(name, "TinyC");
    sprintfStr(s, "name=%s", name);
    check(strcmp(s, "name=TinyC") == 0, "sprintfStr");

    // Append variants
    sprintfInt(s, "a=%d", 1);
    sprintfAppendInt(s, " b=%d", 2);
    sprintfAppendInt(s, " c=%d", 3);
    check(strcmp(s, "a=1 b=2 c=3") == 0, "sprintfAppend chain");
}

void test_strtoken() {
    print("--- strToken ---\n");
    char src[64];
    char tok[32];
    int r;

    // Delimiter-based tokenizing
    strcpy(src, "alpha,beta,gamma,delta");
    r = strToken(src, tok, ",", 0);
    check(strcmp(tok, "alpha") == 0, "token 0");
    r = strToken(src, tok, ",", 1);
    check(strcmp(tok, "beta") == 0, "token 1");
    r = strToken(src, tok, ",", 2);
    check(strcmp(tok, "gamma") == 0, "token 2");
    r = strToken(src, tok, ",", 3);
    check(strcmp(tok, "delta") == 0, "token 3");
    r = strToken(src, tok, ",", 4);
    check(r == 0, "token out of range");
}

void test_strsub() {
    print("--- strSub ---\n");
    char src[64];
    char dst[32];

    strcpy(src, "Hello World");
    strSub(src, dst, 6, 5);
    check(strcmp(dst, "World") == 0, "strSub middle");
    strSub(src, dst, 0, 5);
    check(strcmp(dst, "Hello") == 0, "strSub start");
}

void test_strfind() {
    print("--- strFind ---\n");
    char src[64];
    char needle[16];

    strcpy(src, "the quick brown fox");
    strcpy(needle, "quick");
    check(strFind(src, needle) == 4, "strFind found");
    strcpy(needle, "lazy");
    check(strFind(src, needle) < 0, "strFind not found");
}

void test_atoi_atof() {
    print("--- atoi/atof ---\n");
    char s[32];
    strcpy(s, "12345");
    check(atoi(s) == 12345, "atoi positive");
    strcpy(s, "-99");
    check(atoi(s) == -99, "atoi negative");
    strcpy(s, "3.14");
    float f = atof(s);
    check(f > 3.13 && f < 3.15, "atof float");
}

int main() {
    errors = 0;
    tests = 0;
    print("=== String Operations Test Suite ===\n\n");

    test_strlen();
    test_strcmp();
    test_strcat();
    test_sprintf();
    test_strtoken();
    test_strsub();
    test_strfind();
    test_atoi_atof();

    sprintfInt(buf, "\n=== Results: %d tests, ", tests);
    sprintfAppendInt(buf, "%d errors ===\n", errors);
    printStr(buf);
}
