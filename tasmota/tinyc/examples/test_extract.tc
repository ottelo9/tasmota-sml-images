// Test fileExtract: extract 1 day of ATMP_a (outside temperature)
// and WWTMP_a (warm water temp) from energy_15_log.txt
// col 6 = offset 4 after timestamp+date columns
// Use 100-element arrays (>64 → heap) for margin on boundary rows

int main() {
    char from[24];
    char to[24];
    int temp[100];     // ATMP_a — heap allocated (100 > 64)
    int wtemp[100];    // WWTMP_a — heap allocated
    char buf[48];

    strcpy(from, "20.2.26 00:00");
    strcpy(to, "21.2.26 00:00");

    int fh = fileOpen("/energy_15_log.txt", 0);
    if (fh < 0) {
        print("File open failed\n");
        return 1;
    }

    print("Extracting...\n");

    // col_offs=4 -> start at column 6 (ATMP_a), extract 2 arrays
    int rows = fileExtract(fh, from, to, 4, 0, temp, wtemp);
    fileClose(fh);

    sprintfInt(buf, "Rows extracted: %d\n", rows);
    print(buf);

    // Print first 10 values
    int i = 0;
    while (i < 10 && i < rows) {
        sprintfInt(buf, "%d: ", i);
        sprintfAppendFloat(buf, "ATMP=%.1f  ", temp[i]);
        sprintfAppendFloat(buf, "WWTMP=%.1f\n", wtemp[i]);
        print(buf);
        i = i + 1;
    }

    // Print last 3 values
    print("...\n");
    i = rows - 3;
    if (i < 0) i = 0;
    while (i < rows) {
        sprintfInt(buf, "%d: ", i);
        sprintfAppendFloat(buf, "ATMP=%.1f  ", temp[i]);
        sprintfAppendFloat(buf, "WWTMP=%.1f\n", wtemp[i]);
        print(buf);
        i = i + 1;
    }

    return 0;
}
