// ═══════════════════════════════════════════════════════════════════
// DISPLAY
// ═══════════════════════════════════════════════════════════════════

// ─── Draw static display elements (called once from main) ───
void drawStatic() {
    dspText("[Bi0D0z]");   // clear display
    // Separator lines
    dspText("[x0y45h320]");
    dspText("[x0y90h320]");
    // Labels (Ci5=yellow)
    dspText("[Ci5f2s1x5y100]Netz:");
    dspText("[x5y130]Solar:");
    dspText("[x5y160]Batt:");
    dspText("[x5y190]Haus:");
    dspText("[x5y220]Gas:");
    dspText("[D1]");
    dspUpdate();
}

// ─── Update time display (every second) ───
// Uses native display commands: Ci3=green, f4=font4, T=time, tS=seconds
void updateTime() {
    dspText("[Ci3f4x5y10T]");
    dspText("[f4x155y10tS]");
}

// ─── Update sensor values (every 5 seconds) ───
// Uses dspText for values, sprintfInt to build value strings
void updateValues() {
    // Temperature (orange, Ci6) + battery level
    dspText("[f2s1Ci6x5y60p-8]");
    sprintfInt(buf, "%d C", atmp);
    dspDraw(buf);

    dspText("[x140y60p-10]");
    sprintfInt(buf, "%d %%", pwl);
    dspDraw(buf);

    // Power values (cyan, Ci7)
    dspText("[Ci7x150y100p-10]");
    sprintfInt(buf, "%d W", sip);
    dspDraw(buf);

    dspText("[x150y130p-10]");
    sprintfInt(buf, "%d W", sop);
    dspDraw(buf);

    dspText("[x150y160p-10]");
    sprintfInt(buf, "%d W", bip);
    dspDraw(buf);

    dspText("[x150y190p-10]");
    sprintfInt(buf, "%d W", hip);
    dspDraw(buf);

    // Gas
    dspText("[x150y220p-10]");
    sprintfInt(buf, "%d", t_gs);
    dspDraw(buf);
}

// ═══════════════════════════════════════════════════════════════════
// DATA COLLECTION — 15-minute samples into daily ring buffers
// ═══════════════════════════════════════════════════════════════════
void collectDaily() {
    // Store current values into daily arrays (all float)
    t_wr4[d_pos] = sedc;               // Dach (roof PV)
    t_wr1[d_pos] = 0.0 - wrga;         // Garage PV
    t_wr2[d_pos] = 0.0 - wrgh;         // Gartenhaus PV
    t_wr3[d_pos] = 0.0 - wrgg;         // Garten PV
    t_hv[d_pos]  = hip;                // Haus (house consumption)
    t_ni[d_pos]  = sip;                // Netz (grid import)
    t_pw[d_pos]  = pwl;                // Powerwall %
    t_atmp[d_pos] = atmp;              // Aussentemperatur
    t_ss[d_pos]  = ssp;                // Solarspeicher
    d_pos = d_pos + 1;
    if (d_pos >= 96) { d_pos = 0; }
    if (d_cnt < 96) { d_cnt = d_cnt + 1; }
}

// ═══════════════════════════════════════════════════════════════════
// WEB — Main page sensor display (WebPage callback)
// ═══════════════════════════════════════════════════════════════════
// ─── WebCall: AJAX refresh callback (runs every ~2 seconds) ───
void WebCall() {
    int sr;
    int ss;
    int dl;
    sr = tasm_sunrise;
    ss = tasm_sunset;
    dl = ss - sr;

    // ─── Clock / Date / Sunrise header (as table row) ───
    webSend("<tr><td colspan=2 style='text-align:center;background:#333;padding:8px;border-radius:8px'>");
    webSend("<span style='color:green;font-size:40px;font-weight:bold'>");
    sprintfInt(buf, "%02d:", tasm_hour);
    webSend(buf);
    sprintfInt(buf, "%02d:", tasm_minute);
    webSend(buf);
    sprintfInt(buf, "%02d", tasm_second);
    webSend(buf);
    webSend("</span><br>");
    // Date: weekday day. month year
    strSub(s1, wdays, (tasm_wday - 1) * 3, 2);
    strSub(s2, mons, (tasm_month - 1) * 3, 3);
    sprintfStr(buf, "%s ", s1);
    sprintfAppendInt(buf, "%d. ", tasm_day);
    sprintfAppendStr(buf, "%s ", s2);
    sprintfAppendInt(buf, "%d", tasm_year);
    webSend(buf);
    webSend("<br>");
    // Sunrise --- daylight duration --- Sunset
    webSend("&#127774; ");
    sprintfInt(buf, "%02d:", sr / 60);
    webSend(buf);
    sprintfInt(buf, "%02d", sr % 60);
    webSend(buf);
    webSend(" &lt;--- ");
    sprintfInt(buf, "%d:", dl / 60);
    webSend(buf);
    sprintfInt(buf, "%02d", dl % 60);
    webSend(buf);
    webSend(" ---&gt; ");
    sprintfInt(buf, "%02d:", ss / 60);
    webSend(buf);
    sprintfInt(buf, "%02d", ss % 60);
    webSend(buf);
    webSend(" &#127769;");
    webSend("</td></tr>");

    // ═══════════════════════════════════════════════════════════════
    // Sensor rows — use {s}/{m}/{e} tags for Tasmota table integration
    // Client JS replaces: {s}→<tr><th>, {m}→</th><td...>, {e}→</td></tr>
    // ═══════════════════════════════════════════════════════════════

    // ─── Wasser ───
    // NOTE: sprintfFloat has 64-byte internal buffer limit.
    // Split: webSend("{s}LABEL{m}<span style='color:COLOR'>") then sprintfFloat for value only.
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Wasser</b>{m}{e}");
    webSend("{s}Heute{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f l</span>{e}", (t_ws - was_m) * 1000);
    webSend(buf);
    webSend("{s}Z&auml;hlerstand{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f &#13221;</span>{e}", t_ws);
    webSend(buf);

    // ─── Solarthermie ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Solarthermie</b>{m}{e}");
    webSend("{s}Au&szlig;entemperatur{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.1f &#8451;</span>{e}", atmp);
    webSend(buf);
    webSend("{s}Durchschnittstemperatur{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f &#8451;</span>{e}", avgt);
    webSend(buf);
    webSend("{s}Kellertemperatur{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f &#8451;</span>{e}", ktmp);
    webSend(buf);
    webSend("{s}Solarkollektor{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.1f &#8451;</span>{e}", scol);
    webSend(buf);
    webSend("{s}Solarspeicher{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.1f &#8451;</span>{e}", ssp);
    webSend(buf);

    // ─── Regen ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Regen</b>{m}{e}");
    webSend("{s}Heute{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f mm</span>{e}", hrain);
    webSend(buf);
    webSend("{s}Total{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f mm</span>{e}", train);
    webSend(buf);

    // ─── Haupt Hauszähler ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Haupt Hausz&auml;hler</b>{m}{e}");
    webSend("{s}Verbrauch{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.4f KWh</span>{e}", zwzi);
    webSend(buf);
    webSend("{s}Verbrauch heute{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.4f KWh</span>{e}", zwzi - zrz_m);
    webSend(buf);
    webSend("{s}Einspeisung{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.4f KWh</span>{e}", zwzo);
    webSend(buf);
    webSend("{s}aktueller Verbrauch{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", zwzc);
    webSend(buf);

    // ─── Wallbox ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Wallbox</b>{m}{e}");
    webSend("{s}aktuell{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", auto);
    webSend(buf);
    webSend("{s}heute{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.3f kWh</span>{e}", t_wb - auto_m);
    webSend(buf);
    webSend("{s}Total{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.3f kWh</span>{e}", t_wb);
    webSend(buf);

    // ─── Klima-Anlage ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Klima-Anlage</b>{m}{e}");
    webSend("{s}aktuell{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", 0.0 - klima);
    webSend(buf);
    webSend("{s}Total (+Pool){m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.3f kWh</span>{e}", t_kpwp);
    webSend(buf);

    // ─── Pool-WP ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Pool-WP</b>{m}{e}");
    webSend("{s}aktuell{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", 0.0 - pwp);
    webSend(buf);

    // ─── Brauchwasser-WP ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Brauchwasser-WP</b>{m}{e}");
    webSend("{s}Heute{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f KWh</span>{e}", bwtwp);
    webSend(buf);
    webSend("{s}Total{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f KWh</span>{e}", bwwp);
    webSend(buf);

    // ─── Heizungs-WP ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Heizungs-WP</b>{m}{e}");
    webSend("{s}Heute{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f KWh</span>{e}", t_hwp - hwp_m);
    webSend(buf);
    webSend("{s}aktuell{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", hwp);
    webSend(buf);
    webSend("{s}Total{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.3f KWh</span>{e}", t_hwp);
    webSend(buf);

    // ─── Solar Hausdach ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Solar Hausdach, 5.25 KW</b>{m}{e}");
    webSend("{s}aktuell{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", sedc);
    webSend(buf);
    webSend("{s}Total{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.3f KWh</span>{e}", sedt);
    webSend(buf);

    // ─── Solar Garage ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Solar Garage, 2.42/3.45 KW</b>{m}{e}");
    webSend("{s}aktuell{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", 0.0 - wrga);
    webSend(buf);
    webSend("{s}Total{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.3f kWh</span>{e}", t_ga);
    webSend(buf);

    // ─── Solar Gartenhaus ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Solar Gartenhaus, 1.96/2.8 KW</b>{m}{e}");
    webSend("{s}aktuell{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", 0.0 - wrgh);
    webSend(buf);
    webSend("{s}Total{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.3f kWh</span>{e}", t_gh);
    webSend(buf);

    // ─── Solar Garten ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Solar Garten, 2.87/4.1 KW</b>{m}{e}");
    webSend("{s}aktuell{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", 0.0 - wrgg);
    webSend(buf);
    webSend("{s}Total{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.3f kWh</span>{e}", t_gg);
    webSend(buf);

    // ─── Solar Gesamt ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Solar Gesamt, 7.25/10.35 KW</b>{m}{e}");
    webSend("{s}aktuell{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", 0.0 - (wrga + wrgh + wrgg));
    webSend(buf);

    // ─── Powerwall (mixed colors) ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Powerwall</b>{m}{e}");
    webSend("{s}Batterie F&uuml;llstand{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f %% (", pwl);
    webSend(buf);
    sprintfFloat(buf, "%.2f kWh)</span>{e}", pwl / 100.0 * 13.5);
    webSend(buf);
    webSend("{s}Netz{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f W</span>{e}", sip);
    webSend(buf);
    webSend("{s}Solar{m}<span style='color:green'>");
    sprintfFloat(buf, "%.2f W</span>{e}", sop);
    webSend(buf);
    webSend("{s}Batterie{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f W</span>{e}", bip);
    webSend(buf);
    webSend("{s}Haus{m}<span style='color:red'>");
    sprintfFloat(buf, "%.2f W</span>{e}", hip);
    webSend(buf);
    webSend("{s}Gesamt{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.3f kWh</span>{e}", tcap / 1000.0);
    webSend(buf);
    webSend("{s}Verbleibend{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.3f kWh</span>{e}", rcap / 1000.0);
    webSend(buf);
    webSend("{s}Rcap{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f %%</span>{e}", rper);
    webSend(buf);

    // ─── Büro ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>B&uuml;ro</b>{m}{e}");
    webSend("{s}Temperatur{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f &#8451;</span>{e}", btemp);
    webSend(buf);
    webSend("{s}Feuchte{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f %%</span>{e}", bhumi);
    webSend(buf);
    webSend("{s}Luftdruck{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f hPa</span>{e}", bpress);
    webSend(buf);

    // ─── Schlafzimmer ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Schlafzimmer</b>{m}{e}");
    webSend("{s}Temperatur{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f &#8451;</span>{e}", shtemp);
    webSend(buf);

    // ─── Schlafzimmer G ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Schlafzimmer G</b>{m}{e}");
    webSend("{s}Temperatur{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f &#8451;</span>{e}", aztemp);
    webSend(buf);
    webSend("{s}Feuchte{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f %%</span>{e}", azhumi);
    webSend(buf);
    webSend("{s}TVOC{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f ppb</span>{e}", aztvoc);
    webSend(buf);
    webSend("{s}eCO2{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f ppm</span>{e}", azeco2);
    webSend(buf);

    // ─── Wohnzimmer ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Wohnzimmer</b>{m}{e}");
    webSend("{s}Temperatur{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f &#8451;</span>{e}", wtemp);
    webSend(buf);
    webSend("{s}Feuchte{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.2f %%</span>{e}", whumi);
    webSend(buf);
    webSend("{s}TVOC{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f ppb</span>{e}", wtvoc);
    webSend(buf);
    webSend("{s}CO2{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f ppm</span>{e}", wco2);
    webSend(buf);

    // ─── Phasen ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>Phasen</b>{m}{e}");
    webSend("{s}Phase 1{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", phs1);
    webSend(buf);
    webSend("{s}Phase 2{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", phs2);
    webSend(buf);
    webSend("{s}Phase 3{m}<span style='color:yellow'>");
    sprintfFloat(buf, "%.0f W</span>{e}", phs3);
    webSend(buf);

    // ─── System ───
    webSend("{s}<hr>{m}<hr>{e}{s}<b style='color:magenta'>System</b>{m}{e}");
    sprintfInt(buf, "{s}Heap{m}<span style='color:yellow'>%d kB</span>{e}", tasm_heap / 1000);
    webSend(buf);

    webSend("{s}<hr>{m}<hr>{e}");
}

void WebPage() {
    // ─── Live streaming chart: 4 solar inverters (Chart.js) ───
    webSend("<div><canvas id='schart' style='width:640px;height:300px;'></canvas></div>");
    webSendFile("stream_tc.js");
}

// ═══════════════════════════════════════════════════════════════════
// DATA LOADING — download log databases from data collector
// ═══════════════════════════════════════════════════════════════════

// Build partial download URL with date range suffix
// Data collector runs Scripter — @date filter needs German format: D.M.YY-H:MM
// Uses s1/s2 ISO timestamps, converts to German for URL, keeps s1/s2 intact
void buildUrl(int is15min) {
    // Copy ISO timestamps and convert to German format
    strcpy(dx1, s1);
    timeConvert(dx1, 1);    // "2026-02-20T00:00:00" → "20.2.26 0:00"
    strcpy(dx2, s2);
    timeConvert(dx2, 1);    // "2026-02-28T00:00:00" → "28.2.26 0:00"

    // Replace space with dash for URL: "20.2.26 0:00" → "20.2.26-0:00"
    // strToken is 1-based, delimiter must be char literal (not string)
    strToken(str, dx1, ' ', 1);
    strToken(buf, dx1, ' ', 2);
    dx1 = str;
    dx1 += "-";
    dx1 += buf;

    strToken(str, dx2, ' ', 1);
    strToken(buf, dx2, ' ', 2);
    dx2 = str;
    dx2 += "-";
    dx2 += buf;

    if (is15min == 0) {
        url = "http://192.168.188.61/ufs/energy_m_log.txt@";
    } else {
        url = "http://192.168.188.61/ufs/energy_15_log.txt@";
    }
    url += dx1;
    url += "_";
    url += dx2;
}

// Load week data — download and extract both databases
void loadWeekData() {
    int fr;
    int rows;

    // ── Load 15-minute data (7 days, averaged to hourly) ──
    addLog("TCC: loading 15min data...");
    timeStamp(s1);
    timeOffset(s1, -7, 1);       // 7 days ago midnight
    timeStamp(s2);
    timeOffset(s2, 0, 1);        // today midnight

    buildUrl(1);                  // 15-min DB URL with @date
    dres = fileDownload("/tmplog.txt", url);
    sprintfInt(buf, "TCC: 15min HTTP=%d", dres);
    addLog(buf);

    if (dres == 200) {
        fr = fileOpen("/tmplog.txt", "r");
        if (fr >= 0) {
            // col_offs=1 (skip WB), accum=-4 (average 4 rows -> hourly)
            rows = fileExtract(fr, s1, s2, 1, -4,
                w_wr1, w_wr2, w_wr3, w_at,
                a_du, a_du, a_du,
                w_sk, w_swa, w_wr4,
                a_du, a_du,
                w_wa, w_gas, w_pwl,
                a_du,
                w_sin,
                a_du,
                w_hv);
            fileClose(fr);
            sprintfInt(buf, "TCC: 15min rows=%d", rows);
            addLog(buf);
        }
    }

    // ── Load daily data (9 days, delta mode → 8 rows, skip [0]=0) ──
    addLog("TCC: loading daily data...");
    timeStamp(s1);
    timeOffset(s1, -9, 1);       // 9 days ago midnight
    timeStamp(s2);
    timeOffset(s2, 0, 1);        // today midnight

    buildUrl(0);                  // daily DB URL with @date
    dres = fileDownload("/daylog.txt", url);
    sprintfInt(buf, "TCC: daily HTTP=%d", dres);
    addLog(buf);

    if (dres == 200) {
        fr = fileOpen("/daylog.txt", "r");
        if (fr >= 0) {
            // col_offs=0 (start at WB), accum=-1 (delta)
            rows = fileExtract(fr, s1, s2, 0, -1,
                wt_wb, wt_sin1, wt_sin2, wt_sin3, wt_tmp,
                a_du, a_du, a_du, a_du, a_du,
                wt_sin4, wt_hv, a_du, wt_wa, wt_gas,
                a_du, a_du, a_du, a_du, a_du,
                a_du, a_du, a_du, wt_wp);
            fileClose(fr);
            sprintfInt(buf, "TCC: daily rows=%d", rows);
            addLog(buf);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════
// TASK LOOP — background FreeRTOS task for data loading
// ═══════════════════════════════════════════════════════════════════
void TaskLoop() {
    while (1) {
        if (dotask == 1) {
            addLog("TCC: TaskLoop start");
            loadWeekData();
            wk_loaded = 1;
            dotask = 0;
            addLog("TCC: TaskLoop done");
        }
        delay(2000);
    }
}

