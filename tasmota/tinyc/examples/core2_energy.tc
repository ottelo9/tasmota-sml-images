        // Chart 1: PV power (4 inverters)
        //  WebChart(type, title, unit, color, pos, count, array, dec, interval, ymin, ymax)
        WebChart('l', "Photovoltaik", "W", 0xFF0000, d_pos, d_cnt, t_wr1, 0, 15, 0.0, 5000.0);
        WebChart('l', "", "W", 0x00AA00, d_pos, d_cnt, t_wr2, 0, 15, 0.0, 5000.0);
        WebChart('l', "", "W", 0x0000FF, d_pos, d_cnt, t_wr3, 0, 15, 0.0, 5000.0);
        WebChart('l', "", "W", 0xFF8800, d_pos, d_cnt, t_wr4, 0, 15, 0.0, 5000.0);
        // Chart 2: Grid + House
        WebChart('l', "Netz / Haus", "W", 0x0088FF, d_pos, d_cnt, t_ni, 0, 15, 0.0, 5000.0);
        WebChart('l', "", "W", 0xFF0000, d_pos, d_cnt, t_hv, 0, 15, 0.0, 5000.0);
        // Chart 3: Powerwall charge
        WebChart('l', "Powerwall", "%%", 0x00CC00, d_pos, d_cnt, t_pw, 0, 15, 0.0, 100.0);
        // Chart 4: Temperatures
        WebChart('l', "Temperatur", "C", 0xFF6600, d_pos, d_cnt, t_atmp, 0, 15, 0.0, 40.0);
        WebChart('l', "", "C", 0xCC0000, d_pos, d_cnt, t_ss, 0, 15, 0.0, 40.0);
    }
    if (pg == 1) {
        // ─── Page 1: Letzte Woche (7-day hourly line charts) ───
        webSend("<script>rfsh=0;clearTimeout(lt);</script>");
        webSend("<h3>Letzte Woche</h3>");
