            WebChart('c', "", "WP", 0x8800FF, 8, 7, wt_wp, 1, 1440, 0.0, 0.0);
            // Chart 2: Powerwall & Temperatures
            WebChart('l', "Powerwall / Temperaturen", "%%", 0x00CC00, 0, 168, w_pwl, 0, 60, 0.0, 100.0);
            WebChart('l', "", "C", 0xFF6600, 0, 168, w_at, 1, 60, 0.0, 100.0);
            WebChart('l', "", "C", 0x0000FF, 0, 168, w_sk, 1, 60, 0.0, 100.0);
            WebChart('l', "", "C", 0xCC0000, 0, 168, w_swa, 1, 60, 0.0, 100.0);
            // Chart 3: Power consumption & solar yield
            WebChart('l', "Verbrauch / Solar", "W", 0xFF0000, 0, 168, w_hv, 0, 60, 0.0, 5000.0);
            WebChart('l', "", "W", 0x00AA00, 0, 168, w_sin, 0, 60, 0.0, 5000.0);
            WebChart('l', "", "W", 0xFF8800, 0, 168, w_wr1, 0, 60, 0.0, 5000.0);
