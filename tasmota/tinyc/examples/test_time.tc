// Test: Time functions — timestamp, convert, millis/micros precision
// No hardware dependencies

char buf[256];
int errors;
int tests;

void check(int condition, char name[]) {
    tests = tests + 1;
    if (condition) {
        sprintfStr(buf, "  PASS: %s\n", name);
    } else {
        errors = errors + 1;
        sprintfStr(buf, "  FAIL: %s\n", name);
    }
    printStr(buf);
}

void test_timestamp() {
    print("--- timeStamp ---\n");
    char ts[32];
    timeStamp(ts);
    int len = strlen(ts);
    check(len > 10, "timeStamp not empty");
    sprintfStr(buf, "  Current timestamp: %s\n", ts);
    printStr(buf);
}

void test_millis_micros() {
    print("--- millis / micros ---\n");
    int ms1 = millis();
    check(ms1 > 0, "millis > 0");

    int us1 = micros();
    check(us1 > 0, "micros > 0");

    // Verify millis advances
    delay(100);
    int ms2 = millis();
    int diff = ms2 - ms1;
    check(diff >= 90 && diff <= 200, "millis advances ~100ms");

    char msg[64];
    sprintfInt(msg, "  100ms delay measured: %d ms\n", diff);
    printStr(msg);
}

void test_time_convert() {
    print("--- timeConvert ---\n");
    char ts[32];

    // Convert epoch seconds to time string
    // 1708905600 = 2024-02-26 00:00:00 UTC
    timeConvert(ts, 1708905600);
    int len = strlen(ts);
    check(len > 5, "timeConvert produces string");
    sprintfStr(buf, "  Epoch 1708905600 = %s\n", ts);
    printStr(buf);
}

void test_secs_conversion() {
    print("--- secsToTime / timeToSecs ---\n");
    char ts[32];

    // Convert seconds to HH:MM:SS format
    secsToTime(ts, 3661);  // 1h 1m 1s
    sprintfStr(buf, "  3661 secs = %s\n", ts);
    printStr(buf);

    // Convert back
    strcpy(ts, "01:01:01");
    int secs = timeToSecs(ts);
    check(secs == 3661, "timeToSecs roundtrip");

    secsToTime(ts, 86399);  // 23:59:59
    sprintfStr(buf, "  86399 secs = %s\n", ts);
    printStr(buf);
}

void test_tasm_time() {
    print("--- Tasmota Time Variables ---\n");
    char msg[128];
    sprintfInt(msg, "  Date: %04d-", tasm_year);
    sprintfAppendInt(msg, "%02d-", tasm_month);
    sprintfAppendInt(msg, "%02d\n", tasm_day);
    printStr(msg);
    sprintfInt(msg, "  Time: %02d:", tasm_hour);
    sprintfAppendInt(msg, "%02d:", tasm_minute);
    sprintfAppendInt(msg, "%02d\n", tasm_second);
    printStr(msg);
    sprintfInt(msg, "  Weekday: %d", tasm_wday);
    sprintfAppendInt(msg, " CW: %d\n", tasm_cw);
    printStr(msg);
    sprintfInt(msg, "  Sunrise: %d", tasm_sunrise);
    sprintfAppendInt(msg, " Sunset: %d\n", tasm_sunset);
    printStr(msg);
    sprintfInt(msg, "  Epoch: %d\n", tasm_time);
    printStr(msg);

    check(tasm_time > 1700000000, "epoch > 2023");
}

int main() {
    errors = 0;
    tests = 0;
    print("=== Time Functions Test Suite ===\n\n");

    test_timestamp();
    test_millis_micros();
    test_time_convert();
    test_secs_conversion();
    test_tasm_time();

    sprintfInt(buf, "\n=== Results: %d tests, ", tests);
    sprintfAppendInt(buf, "%d errors ===\n", errors);
    printStr(buf);
}
